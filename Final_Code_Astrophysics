# ---------------------------------------------------------------
# Simulation data directory and filtering
# ---------------------------------------------------------------
nam = ''
do  = {nam: ['test']}
wdir = '/scratch/1/users/amtaava/'  # Path to simulation data

all_files = os.listdir(wdir)
dirs = [directory for directory in all_files if os.path.isdir(os.path.join(wdir, directory))]  # List all simulation directories

