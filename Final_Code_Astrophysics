tot  = {key: value for d in (even, odd) for key, value in d.items()}  # Combined dictionary of all modes

print(tot)

# ---------------------------------------------------------------
# Parameters: adjust these to switch between poloidal/toroidal
# and select specific simulations or frequency ranges
# ---------------------------------------------------------------
tab  = tot      # Mode dictionary to use (even for poloidal P, odd for toroidal T)
pot  = 'P'      # 'P' = poloidal, 'T' = toroidal
pots = {'P':'W','T':'Z'}  # Maps potential type to its symbol for axis labels
inif = '1p1'
CT   = '1em2'
tag  = ''

n_colors = len(tab)
c = ["k", "purple", "orange", "cyan", "green", "darkblue", "red", "yellow", "pink", "gray", "#008080", "#BFFF00"]
colours = c
